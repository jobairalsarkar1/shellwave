{
  "name": "shellwave",
  "version": "0.1.6",
  "description": "A terminal-first audio companion for developers.",
  "type": "module",
  "bin": {
    "shellwave": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "build": "npm run clean && tsc && node scripts/make-bin-executable.mjs",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "start": "node dist/cli.js"
  },
  "keywords": [
    "cli",
    "terminal",
    "audio",
    "music",
    "youtube",
    "ink"
  ],
  "author": "",
  "homepage": "https://github.com/jobairalsarkar1/shellwave#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jobairalsarkar1/shellwave.git"
  },
  "bugs": {
    "url": "https://github.com/jobairalsarkar1/shellwave/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "ink": "^5.0.1",
    "react": "^18.3.1",
    "update-notifier": "^7.3.1",
    "youtubei.js": "^17.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/update-notifier": "^6.0.8",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
